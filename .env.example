# know-canvas Hermes 集成所需环境变量
# 复制本文件为 .env.local 后填入真实值, .env.local 已 gitignore

# === Hermes 凭据 (问 [boss] 私聊获取) ===
# 不要把真实密码写到本文件!
VITE_HERMES_BASE=https://ha2.digitalvio.shop
VITE_HERMES_USER=hermes
VITE_HERMES_PASS=ASK_BOSS_DO_NOT_COMMIT

# === 部署形态 (P0 阶段填 local; P1 阶段按 boss 选的方案改) ===
# vps-subpath  → https://ha2.digitalvio.shop/canvas/  (Nginx 反代)
# vps-subdomain → https://canvas.digitalvio.shop/
# cloudflare    → https://canvas.<your-account>.workers.dev/
# local         → http://localhost:5180/  (开发 / 黑客松 demo)
VITE_DEPLOY_TARGET=local
VITE_CANVAS_PUBLIC_URL=http://localhost:5180

# === Worker / 后端 (P1 阶段需要; P0 用 local 直连) ===
# P0 阶段, 浏览器直接调 Hermes Kanban API (因为同机部署 + 临时凭据)
# P1 阶段, Worker 隔在中间, 浏览器只跟 Worker 说话, 凭据完全在 Worker 端
VITE_WORKER_BASE_URL=
VITE_WS_URL=

# === Hermes Worker Profile 名 (lichang333 在 dashboard 创建后告诉 ui-cc) ===
# 默认 demo 用的 profile, 没填则 dispatch 会 skipped_unassigned
VITE_DEFAULT_ASSIGNEE=

# === 开发 / 调试 ===
# true  = 不真调 Hermes, 用本地 mock (开发期默认开)
# false = 真调 ha2.digitalvio.shop (demo 时关)
VITE_USE_MOCK_HERMES=true

# === 自定义 User-Agent (反爬关键, 不要去掉) ===
# Hermes 的 Nginx 反爬中间件会拒绝默认 fetch UA (返回 403)
# 任何对 Hermes 的请求都必须带这个 UA
VITE_HERMES_UA=Mozilla/5.0 (compatible; know-canvas/0.1; +https://github.com/nieao/know-canvas)
